@baseUrl = http://localhost:5131
@merchantId = mch_7993b79cadbc4612

### healthchecker
GET {{baseUrl}}/healthchecker

### Swagger UI
GET {{baseUrl}}/swagger-ui/

### ===== MERCHANT =====

### Get All Merchants
GET {{baseUrl}}/merchants

### Search Merchants
GET {{baseUrl}}/merchants?status=li|INACTIVE&order_name=business_name&order_direction=1

### Create Merchant
POST {{baseUrl}}/merchants
Content-Type: application/json

{
  "business_name": "Acme Corp",
  "email": "contact@acme.example",
  "phone": "1234567890",
  "business_type": "COMPANY",
  "kyc_status": "PENDING",
  "status": "ACTIVE"
}

### Get Merchant By ID
GET {{baseUrl}}/merchants/{{merchantId}}

### Update Merchant
PATCH {{baseUrl}}/merchants/{{merchantId}}
Content-Type: application/json

{
  "business_name": "Acme Corp Updated",
  "status": "INACTIVE"
}

### Delete Merchant
DELETE {{baseUrl}}/merchants/mch_2c60d3fe5aeb4736

### ===== API KEYS =====

### Create API Key
POST {{baseUrl}}/api-keys
Content-Type: application/json

{
  "environment": "production",
  "api_key": "my-secret-api-key-value",
  "merchant_id": "{{merchantId}}"
}

### Get API Key By ID
@apiKeyId = 1
GET {{baseUrl}}/api-keys/{{apiKeyId}}

### Get API Keys by Merchant
GET {{baseUrl}}/api-keys/merchant/{{merchantId}}

### Get API Keys (filter/pagination)
GET {{baseUrl}}/api-keys?page=1&size=20&order_name=created_at&order_direction=1

### Update API Key
PATCH {{baseUrl}}/api-keys/{{apiKeyId}}
Content-Type: application/json

{
  "environment": "staging",
  "api_key": "my-updated-api-key-value"
}

### Delete API Key
DELETE {{baseUrl}}/api-keys/2
