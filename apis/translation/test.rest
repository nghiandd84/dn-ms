### ===== PROJECTS =====

### Get All Projects
GET {{baseUrl}}/projects
baggage: {{baggage}}

### Search Projects
GET {{baseUrl}}/projects?default_locale=li|en&order_name=default_locale&order_direction=1
baggage: {{baggage}}

### Create Project
POST {{baseUrl}}/projects
Content-Type: application/json
baggage: {{baggage}}

{
  "name": "My App",
  "api_key": "app_key_12345",
  "default_locale": "en"
}

### Get Project By ID
GET {{baseUrl}}/projects/{{projectId}}
baggage: {{baggage}}

### Update Project
PATCH {{baseUrl}}/projects/{{projectId}}
Content-Type: application/json
baggage: {{baggage}}

{
  "name": "My App Updated",
  "default_locale": "es"
}

### Delete Project
DELETE {{baseUrl}}/projects/{{projectId}}
baggage: {{baggage}}

### ===== TRANSLATION KEYS =====

### Get All Translation Keys
GET {{baseUrl}}/translation-keys
baggage: {{baggage}}

### Create Translation Key
POST {{baseUrl}}/translation-keys
Content-Type: application/json
baggage: {{baggage}}

{
  "project_id": "{{projectId}}",
  "key_name": "welcome_message",
  "description": "Welcome message on home page"
}

### Get Translation Key By ID
GET {{baseUrl}}/translation-keys/{{keyId}}
baggage: {{baggage}}

### Get Translation Keys by Project
GET {{baseUrl}}/projects/{{projectId}}/translation-keys
baggage: {{baggage}}

### Update Translation Key
PATCH {{baseUrl}}/translation-keys/{{keyId}}
Content-Type: application/json
baggage: {{baggage}}

{
  "key_name": "welcome_message_updated",
  "description": "Updated welcome message"
}

### Assign Tag
POST {{baseUrl}}/translation-keys/{{keyId}}/assign-tags
Content-Type: application/json
baggage: {{baggage}}

{
  "tag_ids": ["{{tagId}}", "96010d85-39d6-444f-9940-c0a85b9d97b3"]
}

### UnAssign Tag
POST {{baseUrl}}/translation-keys/{{keyId}}/unassign-tags
Content-Type: application/json
baggage: {{baggage}}

{
  "tag_ids": ["{{tagId}}", "96010d85-39d6-444f-9940-c0a85b9d97b3"]
}

### Delete Translation Key
DELETE {{baseUrl}}/translation-keys/{{keyId}}
baggage: {{baggage}}

