# -----------------------------------------------------------------------------
# PostgreSQL Credentials for Docker Compose
# -----------------------------------------------------------------------------
POSTGRES_USER=dn_ms
POSTGRES_PASSWORD=password123
POSTGRES_DB=dn_ms

# -----------------------------------------------------------------------------
# pgAdmin4 Credentials for Docker Compose
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=password123
PGADMIN_LISTEN_PORT=80


# -----------------------------------------------------------------------------
# Database (PostgreSQL - Docker)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:password123@localhost:5432/dn_ms?schema=public

# -----------------------------------------------------------------------------
# JSON Web Token Credentials
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=Rust!@App(&589)
JWT_MAXAGE=60


# -----------------------------------------------------------------------------
# Service Discovery
# -----------------------------------------------------------------------------
CONSUL_HTTP_ADDR=http://127.0.0.1:8500
HTTP_PROTOCOL=http


# -----------------------------------------------------------------------------
# ERROR Kafka
# -----------------------------------------------------------------------------
# Kafka Error server
ERROR_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Kafka topic to save error
ERROR_KAFKA_TOPIC=error_log
# otel::tracing=trace and axum_tracing_opentelemetry=trace, sea_orm::driver::sqlx_postgres=trace to enable tracing
RUST_LOG=debug,otel::tracing=trace,axum_tracing_opentelemetry=trace,sea_orm::driver::sqlx_postgres=info,opentelemetry_sdk=info,opentelemetry-http=info,hyper_util=info,opentelemetry-otlp=info,sqlx::query=info,sea_orm=info,sqlx=info,reqwest=info,neli=info,tower_http=info,opentelemetry=info,tracing_opentelemetry=info
# RUST_LOG=trace
# RUST_LOG=debug,sea_orm::driver::sqlx_postgres=trace
RUST_LOG_DIRECTORY=./logs
# Death Letter Queue
DLQ_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DLQ_KAFKA_TOPIC=dlq


# -----------------------------------------------------------------------------
# Opentelemetry config
# -----------------------------------------------------------------------------
# HTTP Protocol
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4321
# OTEL_EXPORTER_OTLP_TRACES_HEADERS=key1=value1,key2=value2
# GPRC Protocol
# use .with_tonic();
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4319/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://127.0.0.1:4319/v1/logs



