# -----------------------------------------------------------------------------
# PostgreSQL Credentials for Docker Compose
# -----------------------------------------------------------------------------
POSTGRES_USER=dn_ms
POSTGRES_PASSWORD=password123
POSTGRES_DB=dn_ms

# -----------------------------------------------------------------------------
# pgAdmin4 Credentials for Docker Compose
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=password123
PGADMIN_LISTEN_PORT=80


# -----------------------------------------------------------------------------
# Database (PostgreSQL - Docker)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://postgres:password123@localhost:5432/dn_ms?schema=public

# -----------------------------------------------------------------------------
# JSON Web Token Credentials
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=Rust!@App(&589)
JWT_MAXAGE=60


# -----------------------------------------------------------------------------
# Service Discovery
# -----------------------------------------------------------------------------
CONSUL_HTTP_ADDR=http://127.0.0.1:8500
HTTP_PROTOCOL=http


# -----------------------------------------------------------------------------
# ERROR Kafka
# -----------------------------------------------------------------------------
# Kafka Error server
ERROR_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Kafka topic to save error
ERROR_KAFKA_TOPIC=error_log
RUST_LOG=info
RUST_LOG_DIRECTORY=./logs
# Death Letter Queue
DLQ_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DLQ_KAFKA_TOPIC=dlq


# -----------------------------------------------------------------------------
# Opentelemetry config
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_TRACES_HEADERS=key1=value1,key2=value2
# HTTP Protocol
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4321/v1/traces
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://127.0.0.1:4321/v1/logs
# GPRC Protocol
# use .with_tonic();
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4319/v1/traces
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://127.0.0.1:4319/v1/logs



# -----------------------------------------------------------------------------
# AUTH api
# Run on postgres database version 12. the function pubic.uuid_generate_v4() will work
# CREATE EXTENSION "uuid-ossp";
# -----------------------------------------------------------------------------
AUTH_REDIS_URL=redis://:Redis@123@localhost:6379
AUTH_DATABASE_URL=postgresql://dn_ms:password123@127.0.0.1:5432/dn_ms
AUTH_DATABASE_SCHEME=auth
AUTH_PORT=${AUTH_PORT}
# AUTH_PORT=5101

# -----------------------------------------------------------------------------
# AUTH-WEB App
# -----------------------------------------------------------------------------
AUTH_ENDPOINT_AUTHENTICATE_REQUEST=/requests/code
AUTH_ENDPOINT_LOGIN_PASSWORD=/requests/login
AUTH_ENDPOINT_REGISTER_PASSWORD=/requests/register

# -----------------------------------------------------------------------------
# Bakery api
# -----------------------------------------------------------------------------
BAKERY_REDIS_URL=redis://:Redis@123@localhost:6379
BAKERY_DATABASE_URL=postgresql://dn_ms:password123@127.0.0.1:5432/dn_ms
BAKERY_DATABASE_SCHEME=bakery
BAKERY_PORT=${BAKERY_PORT} 
#BAKERY_PORT=5201

# -----------------------------------------------------------------------------
# Email Template api
# -----------------------------------------------------------------------------
EMAIL_TEMPLATE_REDIS_URL=redis://:Redis@123@localhost:6379
EMAIL_TEMPLATE_DATABASE_URL=postgresql://dn_ms:password123@127.0.0.1:5432/dn_ms
EMAIL_TEMPLATE_DATABASE_SCHEME=email_template
EMAIL_TEMPLATE_PORT=${EMAIL_TEMPLATE_PORT} 
#BAKERY_PORT=5301


# -----------------------------------------------------------------------------
# Notification API
# -----------------------------------------------------------------------------
NOTIFICATION_REDIS_URL=redis://:Redis@123@localhost:6379
NOTIFICATION_DATABASE_URL=postgresql://dn_ms:password123@127.0.0.1:5432/dn_ms
NOTIFICATION_DATABASE_SCHEME=notification
NOTIFICATION_PORT=${NOTIFICATION_PORT} 
#NOTIFICATION_PORT=5401



# -----------------------------------------------------------------------------
# Notification App
# -----------------------------------------------------------------------------
NOTIFICATION_APP_REDIS_URL=redis://:Redis@123@localhost:6379
NOTIFICATION_APP_DATABASE_URL=postgresql://dn_ms:password123@127.0.0.1:5432/dn_ms
NOTIFICATION_APP_DATABASE_SCHEME=notification_app
NOTIFICATION_APP_PORT=${NOTIFICATION_APP_PORT} 
#NOTIFICATION_PORT=5401
NOTIFICATION_APP_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NOTIFICATION_APP_KAFKA_TOPIC=notification_topic
AUTH_SERVER=http://localhost:5101
AUTH_ENDPOINT_VERIFY_TOKEN=/tokens/verify


